{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "esModuleInterop": true,    // <-- Agrega o cambia a true
    "allowSyntheticDefaultImports": true, // <-- Agrega o cambia a true
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
